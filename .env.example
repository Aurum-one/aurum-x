# Aurum — frontend env vars (Next.js)
# Copy to .env.local and fill in.

# Deployed AurumX address on Base Mainnet. Leave the zero address until deploy.
NEXT_PUBLIC_AURX_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: dedicated Base RPC (Alchemy / QuickNode / etc).
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Optional but recommended: WalletConnect Cloud project id.
# https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
