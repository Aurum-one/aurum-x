# Aurum — contracts (Foundry)
# Copy to .env and source before running forge script.

# RPC endpoints used by foundry.toml.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key (used for --verify).
BASESCAN_API_KEY=

# Constructor inputs.
# Dedicated dev wallet that receives claim fees.
DEV_WALLET=

# Optional: difficulty target (uint256). Lower = harder.
# Default in Deploy.s.sol: type(uint256).max / 500_000
# INITIAL_TARGET=

# Optional: ETH fee per mine() call. Default = 0.0001 ETH = 100000000000000 wei.
# CLAIM_FEE=100000000000000

# Required for broadcast — DO NOT COMMIT.
PRIVATE_KEY=
